\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{zh_CN-systemfonts}[2026/02/18 zh_CN system fonts (macOS modern)]

\RequirePackage{fontspec}
\RequirePackage{xeCJK}

% Cross-platform resume-friendly fonts with predictable output.
% Main text: Noto Serif CJK SC (Source Han Serif)
% Headings: Noto Sans CJK SC (Source Han Sans)
% Emphasis: Kaiti SC if available, otherwise fall back to main.

\newcommand*{\ResumeCJKMainFont}{}
\newcommand*{\ResumeCJKSansFont}{}
\newcommand*{\ResumeCJKMonoFont}{}

\IfFontExistsTF{Noto Serif CJK SC}{
  \renewcommand*{\ResumeCJKMainFont}{Noto Serif CJK SC}
}{
  \renewcommand*{\ResumeCJKMainFont}{Noto Sans CJK SC}
}

\IfFontExistsTF{Noto Sans CJK SC Bold}{
  \setCJKmainfont[BoldFont=Noto Sans CJK SC Bold]{\ResumeCJKMainFont}
}{
  \setCJKmainfont{\ResumeCJKMainFont}
}

\renewcommand*{\ResumeCJKSansFont}{Noto Sans CJK SC}

\IfFontExistsTF{Noto Sans CJK SC Bold}{
  \setCJKsansfont[BoldFont=Noto Sans CJK SC Bold]{\ResumeCJKSansFont}
}{
  \setCJKsansfont{\ResumeCJKSansFont}
}

\IfFontExistsTF{Noto Sans Mono CJK SC}{
  \renewcommand*{\ResumeCJKMonoFont}{Noto Sans Mono CJK SC}
}{
  \renewcommand*{\ResumeCJKMonoFont}{Noto Sans CJK SC}
}

\IfFontExistsTF{Noto Sans Mono CJK SC Bold}{
  \setCJKmonofont[BoldFont=Noto Sans Mono CJK SC Bold]{\ResumeCJKMonoFont}
}{
  \setCJKmonofont{\ResumeCJKMonoFont}
}

\setCJKfamilyfont{zhsong}{\ResumeCJKMainFont}

\setCJKfamilyfont{zhhei}{\ResumeCJKSansFont}

\setCJKfamilyfont{zhfs}{\ResumeCJKMainFont}
\IfFontExistsTF{Kaiti SC}{
  \setCJKfamilyfont{zhkai}{Kaiti SC}
}{
  \setCJKfamilyfont{zhkai}{\ResumeCJKMainFont}
}

\newcommand*{\songti}{\CJKfamily{zhsong}}
\newcommand*{\heiti}{\CJKfamily{zhhei}}
\newcommand*{\kaishu}{\CJKfamily{zhkai}}
\newcommand*{\fangsong}{\CJKfamily{zhfs}}

\endinput
