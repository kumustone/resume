\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{zh_CN-systemfonts}[2026/02/24 zh_CN system fonts (macOS Hiragino)]

\RequirePackage{fontspec}
\RequirePackage{xeCJK}

% macOS 现代简历字体方案：
% - 正文：PingFang SC（更现代）
% - 标题/强调：PingFang SC Semibold
% - 回退：Heiti SC
% - 辅助：Kaiti SC / STFangsong

\IfFontExistsTF{PingFang SC}{
  \setCJKmainfont[BoldFont={PingFang SC Semibold}]{PingFang SC}
  \setCJKsansfont[BoldFont={PingFang SC Semibold}]{PingFang SC}
  \setCJKmonofont{Heiti SC}
}{
  \setCJKmainfont{Heiti SC}
  \setCJKsansfont{Heiti SC}
  \setCJKmonofont{Heiti SC}
}

\IfFontExistsTF{PingFang SC}{
  \setCJKfamilyfont{zhsong}[BoldFont={PingFang SC Semibold}]{PingFang SC}
  \setCJKfamilyfont{zhhei}[BoldFont={PingFang SC Semibold}]{PingFang SC}
}{
  \setCJKfamilyfont{zhsong}{Heiti SC}
  \setCJKfamilyfont{zhhei}{Heiti SC}
}

\IfFontExistsTF{STFangsong}{
  \setCJKfamilyfont{zhfs}{STFangsong}
}{
  \IfFontExistsTF{PingFang SC}{
    \setCJKfamilyfont{zhfs}{PingFang SC}
  }{
    \setCJKfamilyfont{zhfs}{Heiti SC}
  }
}
\IfFontExistsTF{Kaiti SC}{
  \setCJKfamilyfont{zhkai}{Kaiti SC}[AutoFakeBold=2]
}{
  \IfFontExistsTF{PingFang SC}{
    \setCJKfamilyfont{zhkai}{PingFang SC}
  }{
    \setCJKfamilyfont{zhkai}{Heiti SC}
  }
}

\newcommand*{\songti}{\CJKfamily{zhsong}}
\newcommand*{\heiti}{\CJKfamily{zhhei}}
\newcommand*{\kaishu}{\CJKfamily{zhkai}}
\newcommand*{\fangsong}{\CJKfamily{zhfs}}

\endinput
