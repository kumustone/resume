\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{zh_CN-systemfonts}[2026/02/18 zh_CN system fonts (macOS modern)]

\RequirePackage{fontspec}
\RequirePackage{xeCJK}

% Noto Sans CJK SC - clean, modern, Notion-style sans-serif
% Weights available: Thin / DemiLight / Light / Regular / Medium / Bold / Black
\setCJKmainfont[
  BoldFont=Noto Sans CJK SC Bold,
  ItalicFont=Noto Sans CJK SC Medium,
  SmallCapsFont=Noto Sans CJK SC Bold
]{Noto Sans CJK SC}

\setCJKsansfont[BoldFont=Noto Sans CJK SC Bold]{Noto Sans CJK SC}
\setCJKmonofont{Noto Sans CJK SC}

\setCJKfamilyfont{zhsong}{Noto Sans CJK SC Light}
\setCJKfamilyfont{zhhei}{Noto Sans CJK SC Bold}
\setCJKfamilyfont{zhfs}{Noto Sans CJK SC}
\setCJKfamilyfont{zhkai}{Noto Sans CJK SC Medium}

\newcommand*{\songti}{\CJKfamily{zhsong}}
\newcommand*{\heiti}{\CJKfamily{zhhei}}
\newcommand*{\kaishu}{\CJKfamily{zhkai}}
\newcommand*{\fangsong}{\CJKfamily{zhfs}}

\endinput
